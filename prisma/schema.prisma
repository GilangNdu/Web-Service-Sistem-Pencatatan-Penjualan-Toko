generator client {
  provider     = "prisma-client"
  output       = "./generated/client"
  moduleFormat = "esm"
}

datasource db {
  provider = "mysql"
}

model product {
  id              Int               @id @default(autoincrement())
  name            String
  slug            String            @unique(map: "Product_slug_key")
  sku             String            @unique(map: "Product_sku_key")
  price           Decimal           @db.Decimal(10, 2)
  stock           Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  transactionitem transactionitem[]
}

model transaction {
  id              Int               @id @default(autoincrement())
  invoiceNo       String            @unique(map: "Transaction_invoiceNo_key")
  totalPrice      Decimal           @db.Decimal(10, 2)
  cashPaid        Decimal           @db.Decimal(10, 2)
  cashReturn      Decimal           @db.Decimal(10, 2)
  userId          Int
  createdAt       DateTime          @default(now())
  user            user              @relation(fields: [userId], references: [id], map: "Transaction_userId_fkey")
  transactionitem transactionitem[]

  @@index([userId], map: "Transaction_userId_fkey")
}

model transactionitem {
  id            Int         @id @default(autoincrement())
  transactionId Int
  productId     Int
  quantity      Int
  subTotal      Decimal     @db.Decimal(10, 2)
  product       product     @relation(fields: [productId], references: [id], map: "TransactionItem_productId_fkey")
  transaction   transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade, map: "TransactionItem_transactionId_fkey")

  @@index([productId], map: "TransactionItem_productId_fkey")
  @@index([transactionId], map: "TransactionItem_transactionId_fkey")
}

model user {
  id          Int           @id @default(autoincrement())
  username    String        @unique(map: "User_username_key")
  password    String
  name        String
  role        user_role     @default(CASHIER)
  createdAt   DateTime      @default(now())
  transaction transaction[]
}

enum user_role {
  ADMIN
  CASHIER
}

model Sale {
  id            Int      @id @default(autoincrement())
  invoiceNo     String   @unique @db.VarChar(100)
  productName   String   @db.VarChar(255)
  buyerName     String?  @db.VarChar(255)
  quantity      Int
  unitPrice     Decimal  @db.Decimal(12, 2)
  totalPrice    Decimal  @db.Decimal(12, 2)
  paymentMethod String   @db.VarChar(50)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("sales")
}
